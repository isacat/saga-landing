<script>
var pcomp_cur=0;
function goTo_comp(idx){
  var screens=['pcomp_s1','pcomp_s2','pcomp_s3','pcomp_s4','pcomp_s5'];
  document.getElementById(screens[pcomp_cur]).classList.add('exit');
  document.getElementById(screens[idx]).classList.add('active');
  setTimeout(function(){document.getElementById(screens[pcomp_cur]).classList.remove('active','exit');pcomp_cur=idx;},500);
  if(idx===1) startWA_comp();
}
function startWA_comp(){
  var msgs=document.getElementById('pcomp_msgs').querySelectorAll('.dmsg');
  msgs.forEach(function(m,i){setTimeout(function(){m.classList.add('show');},500+i*700);});
  setTimeout(function(){
    document.getElementById('pcomp_conc').classList.add('show');
    document.getElementById('pcomp_btn2').style.opacity='1';
    document.getElementById('pcomp_btn2').onclick=function(){goTo_comp(2);};
  },(500+5*700));
}
function pickMythe_comp(){
  var m=document.getElementById('pcomp_mythe');
  m.style.background='rgba(16,185,129,0.15)';m.style.borderColor='rgba(16,185,129,0.6)';m.style.color='#6ee7b7';
  document.getElementById('pcomp_fb3').classList.add('show');
  document.getElementById('pcomp_card3').style.borderColor='rgba(16,185,129,0.4)';
  var btn=document.getElementById('pcomp_btn3');btn.classList.remove('disabled');btn.onclick=function(){goTo_comp(3);startExo_comp();};
}
var pcomp_exoStep=0,pcomp_exoT=null;
var pcomp_exoData=[
  ['🪞','Pense à quelqu\'un que tu envies.','Une personne précise. Pas un idéal.'],
  ['🔍','Qu\'est-ce que tu lui envies exactement ?','Pas sa vie entière. Un truc précis.'],
  ['💡','Est-ce que c\'est quelque chose que toi tu veux vraiment ?','Ou quelque chose que tu penses devoir vouloir ?']
];
function startExo_comp(){pcomp_exoStep=0;runExoStep_comp();}
function runExoStep_comp(){
  var steps=document.getElementById('pcomp_exo_steps').querySelectorAll('.dexo-step');
  steps.forEach(function(s,i){s.style.opacity=i===pcomp_exoStep?'1':'0.3';});
  document.getElementById('pcomp_exo_emoji').textContent=pcomp_exoData[pcomp_exoStep][0];
  var fill=document.getElementById('pcomp_exofill'),pct=0;
  if(pcomp_exoT)clearInterval(pcomp_exoT);
  pcomp_exoT=setInterval(function(){
    pct+=2;fill.style.width=pct+'%';
    if(pct>=100){
      clearInterval(pcomp_exoT);pcomp_exoStep++;
      if(pcomp_exoStep<pcomp_exoData.length){fill.style.width='0%';setTimeout(runExoStep_comp,300);}
      else{var btn=document.getElementById('pcomp_btn4');btn.classList.remove('disabled');btn.onclick=function(){goTo_comp(4);startHold_comp();};}
    }
  },80);
}
function startHold_comp(){
  var hold=document.getElementById('pcomp_hold'),fill=document.getElementById('pcomp_hfill'),p=0,t=null;
  hold.addEventListener('mousedown',startH);hold.addEventListener('touchstart',startH,{passive:true});
  hold.addEventListener('mouseup',stopH);hold.addEventListener('mouseleave',stopH);hold.addEventListener('touchend',stopH);
  function startH(){t=setInterval(function(){p+=3;fill.style.width=p+'%';if(p>=100){clearInterval(t);document.getElementById('pcomp_htxt').textContent="C'est noté !";fill.style.background='rgba(16,185,129,0.3)';var btn=document.getElementById('pcomp_btn5');btn.classList.remove('disabled');btn.onclick=function(){alert('J1 terminé ! ✨');};}}  ,50);}
  function stopH(){clearInterval(t);if(p<100){p=0;fill.style.width='0%';}}
}
var pcomp_started=false;
new IntersectionObserver(function(entries){
  entries.forEach(function(e){if(e.isIntersecting&&!pcomp_started){pcomp_started=true;}});
},{threshold:0.3}).observe(document.getElementById('phone_comp'));
</script>

